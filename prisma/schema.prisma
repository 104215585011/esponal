generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  password           String?
  emailVerified      DateTime?
  image              String?
  plan               Plan                @default(free)
  creditSource       CreditSource        @default(free)
  creditBalanceMinor Int                 @default(0)
  planExpiresAt      DateTime?
  lastRefillAt       DateTime?
  signupGranted      Boolean             @default(false)
  accounts           Account[]
  sessions           Session[]
  words              Word[]
  lecturaReads       LecturaRead[]
  videoViews         VideoView[]
  savedPhrases       SavedPhrase[]
  chatSessions       ChatSession[]
  creditTransactions CreditTransaction[]
  importedDocuments  ImportedDocument[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  free
  premium_m
  premium_y
  ultra_m
  ultra_y
  lifetime_premium
  lifetime_ultra
}

enum CreditSource {
  free
  subscription
  lifetime
}

enum CreditReason {
  grant
  refill
  spend
}

model CreditTransaction {
  id                String       @id @default(cuid())
  userId            String
  deltaMinor        Int
  reason            CreditReason
  refType           String?
  refId             String?
  balanceAfterMinor Int
  createdAt         DateTime     @default(now())
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum WordStatus {
  NEW
  LEARNING
  KNOWN
}

model Word {
  id               String          @id @default(cuid())
  userId           String
  lemma            String
  translation      String
  forms            String[]        @default([])
  dictData         Json?
  partOfSpeech     String?
  status           WordStatus      @default(NEW)
  srsState         String?
  srsDue           DateTime?
  srsStability     Float?
  srsDifficulty    Float?
  srsElapsedDays   Int?
  srsScheduledDays Int?
  srsReps          Int             @default(0)
  srsLapses        Int             @default(0)
  srsLastReview    DateTime?
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  encounters       WordEncounter[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, lemma])
  @@index([userId])
  @@index([userId, srsDue])
}

model WordEncounter {
  id                 String   @id @default(cuid())
  wordId             String
  sourceUrl          String   @db.Text
  timestampSec       Int
  sourceType         String   @default("video")
  courseRef          String?
  originalSentence   String   @db.Text
  translatedSentence String   @db.Text
  word               Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([wordId])
  @@index([sourceType, createdAt])
}

model LecturaRead {
  id     String   @id @default(cuid())
  userId String
  slug   String
  readAt DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId, readAt])
  @@map("lectura_reads")
}

model VideoView {
  id           String   @id @default(cuid())
  userId       String
  videoId      String
  title        String
  channelTitle String
  thumbnail    String?
  viewedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, viewedAt])
  @@map("video_views")
}

model ImportedDocument {
  id           String       @id @default(cuid())
  userId       String
  title        String
  kind         ImportKind
  ossKey       String
  sizeBytes    Int
  unitCount    Int          @default(0)
  lastPosition String       @default("")
  status       ImportStatus @default(ready)
  failReason   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum ImportKind {
  epub
  pdf
}

enum ImportStatus {
  ready
  failed
}

enum LexiconKind {
  word
  construction
  phrase
  collocation
  idiom
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum LexiconStatus {
  vault
  candidate
  review
  rejected
}

model LexiconEntry {
  id            String      @id @default(cuid())
  kind          LexiconKind
  lemma         String
  displayForm   String
  forms         String[]    @default([])
  partOfSpeech  String?
  level         CefrLevel?
  frequency     Int?
  ipa           String?
  audioUrl      String?
  translationZh String?
  translationEn String?
  explanationZh String?
  examples      Json?
  morphology    Json?
  collocations  String[]    @default([])
  sources       String[]    @default([])
  licenseCode   String
  qualityScore  Int         @default(0)
  lookupCount   Int         @default(0)
  status        LexiconStatus @default(vault)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([kind, lemma])
  @@index([level])
  @@index([frequency])
  @@index([lookupCount])
  @@index([status])
}

model SavedPhrase {
  id            String      @id @default(cuid())
  userId        String
  lemma         String
  kind          LexiconKind
  translationZh String?
  explanationZh String?
  data          Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lemma, kind])
  @@index([userId, createdAt])
  @@map("saved_phrases")
}

// === Talk 集成（口语训练）===
// Character: 5 个 AI 对话角色（Emma 英、Jake 美、Sophie 法、Kenji 日、Carlos 西）
// ChatSession: 用户 × 角色的一次对话会话（避开 NextAuth 的 Session）
// ChatMessage: 会话内的单条消息，content 用 AES-256-GCM 加密落库

enum ChatSessionStatus {
  ACTIVE
  ARCHIVED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Character {
  id           String        @id
  name         String
  language     String
  voice        String        @default("")
  bio          String        @default("")
  style        String        @default("")
  systemPrompt String        @db.Text
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]
}

model ChatSession {
  id          String            @id @default(cuid())
  userId      String
  characterId String
  title       String?
  status      ChatSessionStatus @default(ACTIVE)
  archivedAt  DateTime?         @map("archived_at")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character         @relation(fields: [characterId], references: [id], onDelete: Restrict)
  messages    ChatMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([status, archivedAt])
}

model ChatMessage {
  id             String          @id @default(cuid())
  sessionId      String
  role           ChatMessageRole
  content        String          @db.Text
  contentIv      String          @default("")
  contentAuthTag String          @default("")
  corrections    String[]        @default([])
  newWords       String[]        @default([])
  createdAt      DateTime        @default(now())
  session        ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
