{
  "installCommand": "npm install",
  "buildCommand": "npx prisma migrate deploy && npm run build",
  "functions": {
    "src/app/api/subtitle/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/tts/route.ts": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/talk/cron/cleanup-archived",
      "schedule": "0 3 * * *"
    }
  ]
}
