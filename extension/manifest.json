{
  "manifest_version": 3,
  "name": "Esponal",
  "description": "Esponal YouTube learning companion.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Esponal"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js", "dist/harvest.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["dist/esponal-site.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://www.youtube.com/*"
  ],
  "permissions": ["activeTab", "storage"]
}
