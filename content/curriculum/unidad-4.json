  "dialogues": [
    {
      "title": "对话 1 - 服装店购物",
      "scene": "顾客在服装店询问价格和尺码。",
      "lines": [
        {
          "speaker": "Cliente",
          "speakerVariant": "b",
          "es": "Buenas tardes. Cuanto cuesta esta camiseta?",
          "zh": "下午好。这件T恤多少钱？",
          "audioSrc": "/audio/units/unidad-4/buenas-tardes-cuanto-cuesta-esta-camiseta.mp3"
        },
        {
          "speaker": "Dependiente",
          "speakerVariant": "a",
          "es": "Cuesta veinte y cinco euros.",
          "zh": "二十五欧元。",
          "audioSrc": "/audio/units/unidad-4/cuesta-veinte-y-cinco-euros.mp3"
        },
        {
          "speaker": "Cliente",
          "speakerVariant": "b",
          "es": "Tiene en azul? Prefiero el azul al negro.",
          "zh": "有蓝色的吗？比起黑色我更喜欢蓝色。",
          "audioSrc": "/audio/units/unidad-4/tiene-en-azul-prefiero-el-azul-al-negro.mp3"
        },
        {
          "speaker": "Dependiente",
          "speakerVariant": "a",
          "es": "Si, claro. Que talla necesita?",
          "zh": "当然有。您需要什么尺码？",
          "audioSrc": "/audio/units/unidad-4/si-claro-que-talla-necesita.mp3"
        },
        {
          "speaker": "Cliente",
          "speakerVariant": "b",
          "es": "La mediana, creo. Puedo probarmela?",
          "zh": "我觉得是中号。我可以试穿吗？",
          "audioSrc": "/audio/units/unidad-4/la-mediana-creo-puedo-probarmela.mp3"
        },
        {
          "speaker": "Dependiente",
          "speakerVariant": "a",
          "es": "Por supuesto. El probador esta al fondo a la derecha.",
          "zh": "当然可以。试衣间在里面右边。",
          "audioSrc": "/audio/units/unidad-4/por-supuesto-el-probador-esta-al-fondo-a-la-derecha.mp3"
        }
      ]
    },
    {
      "title": "对话 2 - 比较两件商品",
      "scene": "朋友们一起逛街，讨论要买哪件。",
      "lines": [
        {
          "speaker": "Ana",
          "speakerVariant": "a",
          "es": "Cual prefieres, el vestido rojo o el azul?",
          "zh": "你更喜欢哪件，红色还是蓝色的裙子？",
          "audioSrc": "/audio/units/unidad-4/cual-prefieres-el-vestido-rojo-o-el-azul.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Me gusta mas el azul. El rojo me parece demasiado llamativo.",
          "zh": "我更喜欢蓝色的。红色的我觉得太显眼了。",
          "audioSrc": "/audio/units/unidad-4/me-gusta-mas-el-azul-el-rojo-me-parece-demasiado-llamativo.mp3"
        },
        {
          "speaker": "Ana",
          "speakerVariant": "a",
          "es": "Y el precio? El azul cuesta mas.",
          "zh": "价格呢？蓝色的更贵。",
          "audioSrc": "/audio/units/unidad-4/y-el-precio-el-azul-cuesta-mas.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Cuanto cuesta el azul?",
          "zh": "蓝色的多少钱？",
          "audioSrc": "/audio/units/unidad-4/cuanto-cuesta-el-azul.mp3"
        },
        {
          "speaker": "Ana",
          "speakerVariant": "a",
          "es": "Cuesta ochenta euros. Pero esta en oferta, cincuenta.",
          "zh": "八十欧元。但是在打折，五十欧。",
          "audioSrc": "/audio/units/unidad-4/cuesta-ochenta-euros-pero-esta-en-oferta-cincuenta.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Entonces me lo llevo!",
          "zh": "那我就买了！",
          "audioSrc": "/audio/units/unidad-4/entonces-me-lo-llevo.mp3"
        }
      ]
    }
  ],
  "grammarCards": [
    {
      "verb": "gustar",
      "titleZh": "喜欢（反向动词）",
      "lead": "gustar 的结构与中文相反：主语是「喜欢的东西」，人是间接宾语。",
      "tip": "Me gusta = 它让我喜欢（字面），不是 I like",
      "conjugation": [
        {
          "pronoun": "me / te / le",
          "form": "gusta",
          "example": "Me gusta el azul."
        },
        {
          "pronoun": "me / te / le",
          "form": "gustan",
          "example": "Me gustan los zapatos."
        },
        {
          "pronoun": "nos / os / les",
          "form": "gusta / gustan",
          "example": "Nos gustan las ofertas."
        }
      ]
    },
    {
      "verb": "preferir",
      "titleZh": "更喜欢，偏好",
      "lead": "preferir 是 e→ie 变干动词，表达在多个选项中选择偏好。",
      "tip": "Prefiero A a B = 比起B我更喜欢A",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "prefiero",
          "example": "Prefiero el azul al rojo."
        },
        {
          "pronoun": "tu",
          "form": "prefieres",
          "example": "Que prefieres, este o ese?"
        },
        {
          "pronoun": "el / ella",
          "form": "prefiere",
          "example": "Prefiere la talla grande."
        }
      ]
    },
    {
      "verb": "costar",
      "titleZh": "花费，值……钱",
      "lead": "costar 是 o→ue 变干动词，用于询问和说明价格。",
      "tip": "Cuanto cuesta? = 多少钱？（单数）/ Cuanto cuestan? = 多少钱？（复数）",
      "conjugation": [
        {
          "pronoun": "（单数）",
          "form": "cuesta",
          "example": "Cuanto cuesta esta chaqueta?"
        },
        {
          "pronoun": "（复数）",
          "form": "cuestan",
          "example": "Cuanto cuestan estos zapatos?"
        },
        {
          "pronoun": "（yo）",
          "form": "cuesto",
          "example": null
        }
      ]
    }
  ],
  "compareCards": [
    {
      "title": "gustar 的方向",
      "body": "Me gusta 字面是「它让我喜欢」，不是英语式的 I like。所以单数东西用 gusta，复数东西用 gustan：Me gusta el vestido（我喜欢这条裙子）vs Me gustan los zapatos（我喜欢这双鞋）。"
    },
    {
      "title": "形容词的性数一致",
      "body": "西语形容词必须与名词的性（阴/阳）和数（单/复）一致。rojo → roja / rojos / rojas；azul → azul / azules（阴阳同形）。颜色形容词一般放在名词后面。"
    },
    {
      "title": "este / ese / aquel（指示代词）",
      "body": "este（这个，近处）、ese（那个，中距）、aquel（那个，远处）。购物时常用 este / ese：Prefiero este（我更喜欢这个）。同样要与名词性数一致。"
    }
  ],
