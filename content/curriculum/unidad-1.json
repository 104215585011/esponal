  "dialogues": [
    {
      "title": "对话 1 - 第一次见面",
      "scene": "Maria 和 Liu 在咖啡馆排队时聊了起来。",
      "lines": [
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Hola! Como te llamas?",
          "zh": "你好！你叫什么名字？",
          "audioSrc": "/audio/units/unidad-1/hola-como-te-llamas.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Hola, me llamo Liu. Y tu?",
          "zh": "你好，我叫 Liu。你呢？",
          "audioSrc": "/audio/units/unidad-1/hola-me-llamo-liu-y-tu.mp3"
        },
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Yo soy Maria. De donde eres?",
          "zh": "我是 Maria。你是哪里人？",
          "audioSrc": "/audio/units/unidad-1/yo-soy-maria-de-donde-eres.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Soy de China, de Shanghai. Y tu?",
          "zh": "我是中国人，从上海来。你呢？",
          "audioSrc": "/audio/units/unidad-1/soy-de-china-de-shanghai-y-tu.mp3"
        },
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Soy espanola, de Madrid. A que te dedicas?",
          "zh": "我是西班牙人，马德里的。你做什么工作？",
          "audioSrc": "/audio/units/unidad-1/soy-espanola-de-madrid-a-que-te-dedicas.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Soy estudiante. Estudio espanol aqui.",
          "zh": "我是学生。我在这里学西语。",
          "audioSrc": "/audio/units/unidad-1/soy-estudiante-estudio-espanol-aqui.mp3"
        },
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Que bien! Mucho gusto, Liu.",
          "zh": "太好了！很高兴认识你，Liu。",
          "audioSrc": "/audio/units/unidad-1/que-bien-mucho-gusto-liu.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Igualmente.",
          "zh": "我也是。",
          "audioSrc": "/audio/units/unidad-1/igualmente.mp3"
        }
      ]
    },
    {
      "title": "对话 2 - 课堂自我介绍",
      "scene": "第一节西语课，老师让学生做自我介绍。",
      "lines": [
        {
          "speaker": "Profesora",
          "speakerVariant": "a",
          "es": "Hola a todos. Como te llamas tu?",
          "zh": "大家好。你叫什么名字？",
          "audioSrc": "/audio/units/unidad-1/hola-a-todos-como-te-llamas-tu.mp3"
        },
        {
          "speaker": "Wang",
          "speakerVariant": "b",
          "es": "Me llamo Wang. Soy chino, de Beijing. Tengo 28 anos y soy ingeniero.",
          "zh": "我叫 Wang。我是中国人，北京的。我 28 岁，是工程师。",
          "audioSrc": "/audio/units/unidad-1/me-llamo-wang-soy-chino-de-beijing-tengo-28-anos-y-soy-ingeniero.mp3"
        },
        {
          "speaker": "Profesora",
          "speakerVariant": "a",
          "es": "Muy bien, Wang. Y tu?",
          "zh": "很好，Wang。你呢？",
          "audioSrc": "/audio/units/unidad-1/muy-bien-wang-y-tu.mp3"
        },
        {
          "speaker": "Yuki",
          "speakerVariant": "b",
          "es": "Me llamo Yuki, soy japonesa. Tengo 24 anos y soy disenadora.",
          "zh": "我叫 Yuki，是日本人。我 24 岁，是设计师。",
          "audioSrc": "/audio/units/unidad-1/me-llamo-yuki-soy-japonesa-tengo-24-anos-y-soy-disenadora.mp3"
        }
      ]
    }
  ],
  "grammarCards": [
    {
      "verb": "ser",
      "titleZh": "是",
      "lead": "ser 用来表达身份、国籍、职业等本质属性，是必须先背下来的核心不规则动词。",
      "tip": "ser 表示相对稳定的属性，后续会和 estar 对比。",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "soy",
          "example": "Soy chino."
        },
        {
          "pronoun": "tu",
          "form": "eres",
          "example": "Eres estudiante?"
        },
        {
          "pronoun": "el / ella / usted",
          "form": "es",
          "example": "Maria es espanola."
        },
        {
          "pronoun": "nosotros / nosotras",
          "form": "somos",
          "example": "Somos estudiantes."
        },
        {
          "pronoun": "vosotros / vosotras",
          "form": "sois",
          "example": "Sois de China?"
        },
        {
          "pronoun": "ellos / ellas / ustedes",
          "form": "son",
          "example": "Son medicos."
        }
      ]
    },
    {
      "verb": "llamarse",
      "titleZh": "叫做",
      "lead": "llamarse 是反身动词，字面意思是“把自己叫做……”。",
      "tip": null,
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "me llamo",
          "example": "Me llamo Liu."
        },
        {
          "pronoun": "tu",
          "form": "te llamas",
          "example": "Como te llamas?"
        },
        {
          "pronoun": "el / ella",
          "form": "se llama",
          "example": "Se llama Maria."
        },
        {
          "pronoun": "nosotros",
          "form": "nos llamamos",
          "example": null
        },
        {
          "pronoun": "vosotros",
          "form": "os llamais",
          "example": null
        },
        {
          "pronoun": "ellos / ellas",
          "form": "se llaman",
          "example": null
        }
      ]
    },
    {
      "verb": "tener",
      "titleZh": "有，用于年龄",
      "lead": "西语说年龄用 tener，不用 ser。字面意思是“我有 25 年”。",
      "tip": "中文说“我 25 岁”，西语说 Tengo 25 anos。",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "tengo",
          "example": "Tengo 28 anos."
        },
        {
          "pronoun": "tu",
          "form": "tienes",
          "example": "Cuantos anos tienes?"
        },
        {
          "pronoun": "el / ella",
          "form": "tiene",
          "example": "Tiene 30 anos."
        },
        {
          "pronoun": "nosotros",
          "form": "tenemos",
          "example": null
        },
        {
          "pronoun": "vosotros",
          "form": "teneis",
          "example": null
        },
        {
          "pronoun": "ellos / ellas",
          "form": "tienen",
          "example": "Tienen 20 anos."
        }
      ]
    }
  ],
  "compareCards": [
    {
      "title": "中文不分性别，西语要分阴阳性",
      "body": "中文说“中国人”不区分性别；西语要说 <strong>chino</strong> 或 <strong>china</strong>。国籍词和职业词经常有这个区别。"
    },
    {
      "title": "年龄表达用 tener",
      "body": "<table><tr><th>中文</th><th>西语</th><th>字面意思</th></tr><tr><td>我 25 岁</td><td>Tengo 25 anos.</td><td>我有 25 年</td></tr><tr><td>你多大？</td><td>Cuantos anos tienes?</td><td>你有多少年？</td></tr></table>"
    },
    {
      "title": "姓和名的顺序",
      "body": "中文通常是姓 + 名，西语通常是名 + 姓，而且西班牙语姓名里常见两个姓。"
    }
  ],
  "exercises": [
    {
      "type": "fill-in",
      "title": "用 ser 的正确形式填空",
      "questions": [
        "Yo ___ estudiante.",
