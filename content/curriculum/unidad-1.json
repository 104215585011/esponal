  "phrases": [
    {
      "category": "介绍自己",
      "items": [
        {
          "es": "Me llamo Wang.",
          "zh": "我叫 Wang。",
          "audioSrc": "/audio/units/unidad-1/me-llamo-wang.mp3"
        },
        {
          "es": "Soy chino. / Soy china.",
          "zh": "我是中国人。",
          "audioSrc": "/audio/units/unidad-1/soy-chino-soy-china.mp3"
        },
        {
          "es": "Tengo 25 anos.",
          "zh": "我 25 岁。",
          "audioSrc": "/audio/units/unidad-1/tengo-25-anos.mp3"
        },
        {
          "es": "Soy estudiante.",
          "zh": "我是学生。",
          "audioSrc": "/audio/units/unidad-1/soy-estudiante.mp3"
        },
        {
          "es": "Vivo en Shanghai.",
          "zh": "我住在上海。",
          "audioSrc": "/audio/units/unidad-1/vivo-en-shanghai.mp3"
        }
      ]
    },
    {
