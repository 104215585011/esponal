  "dialogues": [
    {
      "title": "对话 1 - 为什么学西语",
      "scene": "两位同学在语言班第一天相互认识。",
      "lines": [
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Hola, por que quieres aprender espanol?",
          "zh": "你好，你为什么想学西班牙语？",
          "audioSrc": "/audio/units/unidad-2/hola-por-que-quieres-aprender-espanol.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Quiero viajar a Espana el ano que viene.",
          "zh": "我明年想去西班牙旅行。",
          "audioSrc": "/audio/units/unidad-2/quiero-viajar-a-espana-el-ano-que-viene.mp3"
        },
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Que interesante! Yo aprendo espanol para el trabajo.",
          "zh": "真有意思！我是为了工作学的。",
          "audioSrc": "/audio/units/unidad-2/que-interesante-yo-aprendo-espanol-para-el-trabajo.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Y cuantos idiomas hablas?",
          "zh": "你会说几种语言？",
          "audioSrc": "/audio/units/unidad-2/y-cuantos-idiomas-hablas.mp3"
        },
        {
          "speaker": "Maria",
          "speakerVariant": "a",
          "es": "Hablo ingles y un poco de frances. Y tu?",
          "zh": "我会说英语，还有一点法语。你呢？",
          "audioSrc": "/audio/units/unidad-2/hablo-ingles-y-un-poco-de-frances-y-tu.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Hablo chino e ingles. El espanol es nuevo para mi.",
          "zh": "我会中文和英语。西班牙语对我来说是新的。",
          "audioSrc": "/audio/units/unidad-2/hablo-chino-e-ingles-el-espanol-es-nuevo-para-mi.mp3"
        }
      ]
    },
    {
      "title": "对话 2 - 在语言学校",
      "scene": "学生向老师询问课程安排和学习建议。",
      "lines": [
        {
          "speaker": "Profesor",
          "speakerVariant": "a",
          "es": "Entiendes cuando hablo despacio?",
          "zh": "我说慢一点你能听懂吗？",
          "audioSrc": "/audio/units/unidad-2/entiendes-cuando-hablo-despacio.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Un poco. No entiendo todo.",
          "zh": "一点点。不是全都听懂。",
          "audioSrc": "/audio/units/unidad-2/un-poco-no-entiendo-todo.mp3"
        },
        {
          "speaker": "Profesor",
          "speakerVariant": "a",
          "es": "Necesitas practicar mucho. Que sabes ya?",
          "zh": "你需要多练习。你已经会什么了？",
          "audioSrc": "/audio/units/unidad-2/necesitas-practicar-mucho-que-sabes-ya.mp3"
        },
        {
          "speaker": "Liu",
          "speakerVariant": "b",
          "es": "Se los numeros y los colores. Quiero aprender mas vocabulario.",
          "zh": "我会数字和颜色。我想学更多词汇。",
          "audioSrc": "/audio/units/unidad-2/se-los-numeros-y-los-colores-quiero-aprender-mas-vocabulario.mp3"
        },
        {
          "speaker": "Profesor",
          "speakerVariant": "a",
          "es": "Muy bien. Debes escuchar espanol cada dia.",
          "zh": "很好。你应该每天听西班牙语。",
          "audioSrc": "/audio/units/unidad-2/muy-bien-debes-escuchar-espanol-cada-dia.mp3"
        }
      ]
    }
  ],
  "grammarCards": [
    {
      "verb": "querer",
      "titleZh": "想要",
      "lead": "querer + infinitivo 表达愿望，是A1最常用句型之一。",
      "tip": "Quiero + 动词原形 = 我想……",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "quiero",
          "example": "Quiero aprender espanol."
        },
        {
          "pronoun": "tu",
          "form": "quieres",
          "example": "Que quieres estudiar?"
        },
        {
          "pronoun": "el / ella",
          "form": "quiere",
          "example": "Quiere viajar a Peru."
        }
      ]
    },
    {
      "verb": "hablar",
      "titleZh": "说（语言）",
      "lead": "hablar 是规则 -ar 动词的典型代表，变位规律适用于大量动词。",
      "tip": "hablo / hablas / habla — 记住这三个就够用",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "hablo",
          "example": "Hablo chino e ingles."
        },
        {
          "pronoun": "tu",
          "form": "hablas",
          "example": "Hablas muy bien el espanol."
        },
        {
          "pronoun": "el / ella",
          "form": "habla",
          "example": "Habla tres idiomas."
        }
      ]
    },
    {
      "verb": "entender",
      "titleZh": "理解，听懂",
      "lead": "entender 是 e→ie 变干动词，主要人称词干元音变化。",
      "tip": "entiendo / entiendes / entiende（注意 ie）",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "entiendo",
          "example": "Entiendo poco el espanol."
        },
        {
          "pronoun": "tu",
          "form": "entiendes",
          "example": "Entiendes cuando habla despacio?"
        },
        {
          "pronoun": "el / ella",
          "form": "entiende",
          "example": "Entiende el chino perfectamente."
        }
      ]
    },
    {
      "verb": "saber",
      "titleZh": "知道，会（知识类）",
      "lead": "saber 的 yo 形式不规则（se），其余按规律变位。",
      "tip": "se（yo）是不规则的，要单独记",
      "conjugation": [
        {
          "pronoun": "yo",
          "form": "se",
          "example": "Se los numeros en espanol."
        },
        {
          "pronoun": "tu",
          "form": "sabes",
          "example": "Sabes cuantos idiomas hay en el mundo?"
        },
        {
          "pronoun": "el / ella",
          "form": "sabe",
          "example": "Sabe hablar bien el frances."
        }
      ]
    }
  ],
  "compareCards": [
    {
      "title": "saber vs conocer（两种「知道」）",
      "body": "saber 表示掌握知识或技能（Se cocinar = 我会做饭），conocer 表示认识某人或某地（Conozco Madrid = 我认识马德里）。英语用同一个 know，西语要区分。"
    },
    {
      "title": "动词 + infinitivo 结构",
      "body": "西语中「想做什么」直接用：querer / necesitar / poder / deber + 动词原形，不需要额外连接词。例：Quiero aprender（想学）、Necesito practicar（需要练习）。"
    },
    {
      "title": "程度副词的位置",
      "body": "bien、mal、mucho、poco 放在动词之后。例：Hablo bien（我说得好）、Entiendo poco（我理解得少）。注意不能放在动词前面。"
    }
  ],
