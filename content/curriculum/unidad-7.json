  "phrases": [
    {
      "category": "点餐",
      "items": [
        {
          "es": "Que nos recomienda?",
          "zh": "您有什么推荐？",
          "audioSrc": "/audio/units/unidad-7/que-nos-recomienda.mp3"
        },
        {
          "es": "Para mi, la ensalada.",
          "zh": "我要沙拉。",
          "audioSrc": "/audio/units/unidad-7/para-mi-la-ensalada.mp3"
        },
        {
          "es": "Quiero pedir el pescado del dia.",
          "zh": "我想点今日特供的鱼。",
          "audioSrc": "/audio/units/unidad-7/quiero-pedir-el-pescado-del-dia.mp3"
        },
        {
          "es": "Nos trae la cuenta, por favor?",
          "zh": "能请您把账单拿来吗？",
          "audioSrc": "/audio/units/unidad-7/nos-trae-la-cuenta-por-favor.mp3"
        }
      ]
    },
    {
      "category": "评价食物",
      "items": [
        {
          "es": "Esta muy rico!",
          "zh": "真的很好吃！",
          "audioSrc": "/audio/units/unidad-7/esta-muy-rico.mp3"
        },
        {
          "es": "Esta un poco salado.",
          "zh": "有点咸。",
          "audioSrc": "/audio/units/unidad-7/esta-un-poco-salado.mp3"
